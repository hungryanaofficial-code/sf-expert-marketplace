generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ARCHITECT
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id            String         @id @default(cuid())
  clerkId       String         @unique
  email         String         @unique
  name          String?
  avatarUrl     String?
  role          UserRole       @default(USER)
  bookmarks     Bookmark[]
  comments      Comment[]
  progress      UserProgress[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  icon        String?
  color       String?
  sortOrder   Int        @default(0)
  questions   Question[]
  articles    Article[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Tag {
  id        String        @id @default(cuid())
  name      String        @unique
  slug      String        @unique
  questions QuestionTag[]
  articles  ArticleTag[]
  createdAt DateTime      @default(now())
}

model Question {
  id                  String        @id @default(cuid())
  slug                String        @unique
  title               String
  difficulty          Difficulty
  categoryId          String
  category            Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  expectedAnswer      String        @db.Text
  followUpQuestions   String[]      @default([])
  realWorldScenario   String        @db.Text
  architectPerspective String       @db.Text
  isPublished         Boolean       @default(true)
  viewCount           Int           @default(0)
  tags                QuestionTag[]
  bookmarks           Bookmark[]
  progress            UserProgress[]
  comments            Comment[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([categoryId])
  @@index([difficulty])
  @@index([isPublished])
}

model QuestionTag {
  questionId String
  tagId      String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([questionId, tagId])
}

model Article {
  id              String        @id @default(cuid())
  slug            String        @unique
  title           String
  excerpt         String
  content         String        @db.Text
  categoryId      String?
  category        Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  status          ArticleStatus @default(DRAFT)
  seoTitle        String?
  seoDescription  String?
  ogImage         String?
  authorName      String        @default("Avijit Patra")
  readTimeMinutes Int           @default(5)
  viewCount       Int           @default(0)
  tags            ArticleTag[]
  comments        Comment[]
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@index([categoryId])
}

model ArticleTag {
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
}

model Bookmark {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, questionId])
  @@index([userId])
}

model UserProgress {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId  String
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  completed   Boolean  @default(false)
  notes       String?  @db.Text
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, questionId])
  @@index([userId])
}

model Comment {
  id         String    @id @default(cuid())
  content    String    @db.Text
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId String?
  question   Question? @relation(fields: [questionId], references: [id], onDelete: Cascade)
  articleId  String?
  article    Article?  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([questionId])
  @@index([articleId])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}
