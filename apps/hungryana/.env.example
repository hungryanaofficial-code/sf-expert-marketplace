# Set in Vercel/hosting dashboard → Environment Variables
# Production value after you own the domain:
NEXT_PUBLIC_SITE_URL=https://hungryana.com

# Optional: Google Analytics 4 (add script in layout when ready)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Optional: Web3Forms for serverless contact form (alternative to mailto)
# NEXT_PUBLIC_WEB3FORMS_KEY=your-key-here

# Update real phone in src/lib/constants.ts before launch
